Options -Indexes

# Ativar motor de reescrita
RewriteEngine On

# Redirecionar blog.bagico.com.br para bagico.com.br/blog
RewriteCond %{HTTP_HOST} ^blog\.bagico\.com\.br$ [NC]
RewriteRule ^(.*)$ https://bagico.com.br/blog/$1 [R=301,L]

# Forçar HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Forçar www
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Não interceptar nada dentro de /blog — deixar o WordPress gerenciar
RewriteCond %{REQUEST_URI} ^/blog [NC]
RewriteRule ^ - [L]

# Redirecionar URLs com .php para URLs sem .php (301 permanente para SEO)
RewriteCond %{THE_REQUEST} /([^.]+)\.php [NC]
RewriteRule ^ /%1 [R=301,L]

# Servir arquivos .php sem extensão na URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ /$1.php [L]

# Página inicial
DirectoryIndex index.php index.html

# Página de erro personalizada
ErrorDocument 404 /404.php
